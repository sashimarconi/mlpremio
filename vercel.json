{
  "redirects": [
    {
      "source": "/semana2026.shop",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/semana2026.shop/index.html",
      "destination": "/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "https://semana2026.shop/assets/:path*"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    }
  ]
}
